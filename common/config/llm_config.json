{
  "openai_style_llm": {
    "description": "Large language model in OpenAI style (e.g., DeepSeek, GPT, etc.)",
    "model": "your-model-name",
    "enable_thinking": true,
    "api": "https://your-openai-style-api-endpoint.com",
    "api_key": "<YOUR_API_KEY>"
  },
  "aoc_chat_llm": {
    "description": "AOC platform chat model (e.g., Qwen3_32B)",
    "model": "Qwen3_32B",
    "enable_thinking": false,
    "api": "http://<YOUR_AOC_HOST>:<PORT>/aoc/openapi/<YOUR_ENDPOINT_ID>",
    "api_key": "dummy",
    "extra": {
      "app_key": "<YOUR_APP_KEY>",
      "app_secret": "<YOUR_APP_SECRET>",
      "authorization": "Bearer <YOUR_BEARER_TOKEN>",
      "api_code": "<YOUR_API_CODE>",
      "api_version": "1.0",
      "scenario_code": "<YOUR_SCENARIO_CODE>",
      "scenario_version": "<YOUR_SCENARIO_VERSION>",
      "ability_code": "<YOUR_ABILITY_CODE>",
      "test_flag": "1",
      "request_template": "{\"model\": \"Qwen3_32B\", \"messages\": [{\"role\": \"user\", \"content\": \"{prompt}\"}], \"chat_template_kwargs\": {\"enable_thinking\": {enable_thinking}}}"
    }
  },
  "aoc_embedding_llm": {
    "description": "AOC platform embedding model (e.g., BGE-M3)",
    "model": "bge-m3",
    "enable_thinking": false,
    "api": "http://<YOUR_AOC_HOST>:<PORT>/aoc/openapi/<YOUR_ENDPOINT_ID>",
    "api_key": "dummy",
    "extra": {
      "app_key": "<YOUR_APP_KEY>",
      "app_secret": "<YOUR_APP_SECRET>",
      "authorization": "Bearer <YOUR_BEARER_TOKEN>",
      "api_code": "<YOUR_API_CODE>",
      "api_version": "1.0",
      "scenario_code": "<YOUR_SCENARIO_CODE>",
      "scenario_version": "<YOUR_SCENARIO_VERSION>",
      "ability_code": "<YOUR_ABILITY_CODE>",
      "test_flag": "1",
      "request_template": "{\"model\": \"bge-m3\", \"input\": \"{prompt}\"}"
    }
  },
  "aoc_reranker_llm": {
    "description": "AOC platform reranker model (e.g., BGE-Reranker-v2-m3)",
    "model": "bge-reranker-v2-m3",
    "enable_thinking": false,
    "api": "http://<YOUR_AOC_HOST>:<PORT>/aoc/openapi/interface/bge-reranker-v2-m3",
    "api_key": "dummy",
    "extra": {
      "app_key": "<YOUR_APP_KEY>",
      "app_secret": "<YOUR_APP_SECRET>",
      "authorization": "Bearer <YOUR_BEARER_TOKEN>",
      "api_code": "<YOUR_API_CODE>",
      "api_version": "1.0",
      "scenario_code": "<YOUR_SCENARIO_CODE>",
      "scenario_version": "<YOUR_SCENARIO_VERSION>",
      "ability_code": "<YOUR_ABILITY_CODE>",
      "test_flag": "1",
      "request_template": "{\"model\": \"bge-reranker-v2-m3\", \"query\": \"{query}\", \"documents\": {documents}}"
    }
  }
}