openssl_conf = openssl_init

[openssl_init]
ssl_conf = ssl_sect

[ssl_sect]
system_default = system_default_sect

[system_default_sect]
# Configure allowed TLS groups - exclude ffdhe2048, include stronger DH groups
# Note: Only applicable to OpenSSL 3.0+, as FFDH group support in TLS 1.3 starts from 3.0
Groups = x25519:prime256v1:x448:secp521r1:secp384r1:ffdhe3072:ffdhe4096:ffdhe6144:ffdhe8192